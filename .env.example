# use "postCreateCommand": "source /.secrets/secrets.env" to load secrets into the container environment on startup (see .devcontainer/devcontainer.json)

# Model config — defaults to Claude Sonnet via Anthropic
# To switch to Ollama later: MODEL_PROVIDER=ollama, MODEL_NAME=mistral
MODEL_PROVIDER=anthropic
MODEL_NAME=claude-sonnet-4-6

# Graph store path (relative to project root)
KUZU_DB_PATH=data/kuzu

# GNN enrichment — async background pass
GNN_ENRICHMENT_ENABLED=true
